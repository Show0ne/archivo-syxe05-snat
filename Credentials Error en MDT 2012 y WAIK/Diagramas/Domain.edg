EndSymbol "block"
{
  LineTo 100
  Fill
  {
    Polygon 4 500,500 1000,300 1000,700 500,500
  }
  Outline
  {
    Polyline 4 500,500 1000,300 1000,700 500,500
  }
}

EndSymbol "stick"
{
  Outline
  {
    Line 500,500 1000,300
    Line 500,500 1000,700
  }
}

EndSymbol "block (solid)"
{
  LineTo 100
  Fill
  {
    Polygon 4 500,500 1000,300 1000,700 500,500
  }
  Outline
  {
    Polyline 4 500,500 1000,300 1000,700 500,500
  }
  Silhouette TRUE
}

